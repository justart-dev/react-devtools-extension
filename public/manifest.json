{
  "manifest_version": 3,
  "name": "Taillog - Console & Network Logger",
  "version": "2.0.0",
  "description": "An all-in-one developer tool for tracking logs, requests, stash, and components while debugging web apps.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Taillog",
    "default_icon": {
      "16": "assets/icons/logo-16.png",
      "48": "assets/icons/logo-48.png",
      "128": "assets/icons/logo-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/logo-16.png",
    "32": "assets/icons/logo-32.png",
    "48": "assets/icons/logo-48.png",
    "128": "assets/icons/logo-128.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "locator-inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
